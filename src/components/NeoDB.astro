---
// NeoDB Card Component (豆瓣风重构版)
interface Props {
  dbUrl: string;
}

const { dbUrl } = Astro.props;
const API_URL = "https://neodb.social/api/me/shelf/item/";
const AUTH_TOKEN = import.meta.env.NEODB_TOKEN;

if (!AUTH_TOKEN) {
  console.error("❌ 警告：未找到 NEODB_TOKEN 环境变量, NeoDB 数据将无法加载！");
}

const itemUuidMatch = dbUrl.match(/.*neodb\.social\/.*\/(.*)/);
if (!itemUuidMatch) {
  throw new Error("Invalid URL format");
}

const itemUuid = itemUuidMatch[1];
const dbApiUrl = `${API_URL}${itemUuid}`;

let dbData;
try {
  const response = await fetch(dbApiUrl, {
    headers: { Authorization: `Bearer ${AUTH_TOKEN}` },
  });
  dbData = await response.json();
} catch (error) {
  console.error("Failed to fetch NeoDB data:", error);
}

const calculateStars = (rating: number) => {
  const starCount = (rating * 5) / 10;
  const fullStars = Math.floor(starCount);
  const halfStar = rating % 2 ? 1 : 0;
  const emptyStars = 5 - (fullStars + halfStar);
  return { fullStars, halfStar, emptyStars };
};

const { fullStars, halfStar, emptyStars } = dbData ? calculateStars(dbData.rating_grade) : { fullStars: 0, halfStar: 0, emptyStars: 5 };

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric', month: '2-digit', day: '2-digit'
  }).format(date).replace(/\//g, '年') + '日';
};
---

{dbData ? (
  <div class="douban-layout">
    {/* 1. 上半部分：官方客观信息（无卡片边框） */}
    <div class="db-official-info">
      <img src={dbData.item.cover_image_url} alt="Cover" class="db-cover" />
      <div class="db-meta">
        <div class="db-title-row">
          <a href={dbUrl} target="_blank" rel="noreferrer" class="db-title">
            {dbData.item.title}
          </a>
          <span class="db-cate">{dbData.item.category}</span>
        </div>
        {/* 官方简介：限制3行高度 */}
        {dbData.item.description && (
          <div class="db-intro">{dbData.item.description}</div>
        )}
      </div>
    </div>

    {/* 2. 下半部分：个人主观短评（灰色小卡片包裹） */}
    <div class="db-personal-review">
      <div class="db-rating-row">
        <span class="db-date">{formatDate(dbData.created_time)} 看过</span>
        <span class="db-stars">
          {[...Array(fullStars)].map(() => <i class="fa-solid fa-star"></i>)}
          {halfStar === 1 && <i class="fa-solid fa-star-half-stroke"></i>}
          {[...Array(emptyStars)].map(() => <i class="fa-regular fa-star"></i>)}
        </span>
      </div>
      <div class="db-comment">
        {/* 这里的 comment_text 才是你真正手打的短评！ */}
        {dbData.comment_text || "*(本月纯打卡，未留短评)*"}
      </div>
    </div>
  </div>
) : (
  <p style="text-align: center;"><small>Failed to fetch content.</small></p>
)}

<style>
/* 豆瓣风排版 CSS */
.douban-layout {
    margin: 2rem 0;
    font-family: var(--font-family, sans-serif);
}

/* 官方信息区：左图右文 */
.db-official-info {
    display: flex;
    gap: 16px;
    margin-bottom: 12px;
}

.db-cover {
    width: 90px;
    height: 125px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15); /* 给海报加点质感 */
    flex-shrink: 0;
}

.db-meta {
    flex: 1;
    overflow: hidden;
}

.db-title-row {
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
}

.db-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--card-text-color-main, #222);
    text-decoration: none;
    line-height: 1.2;
}

.db-cate {
    background: #eef1f6;
    color: #5c75a3;
    padding: 2px 6px;
    font-size: 0.75rem;
    border-radius: 4px;
    text-transform: capitalize;
}

/* 官方简介：限制只显示 3 行 */
.db-intro {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* 个人评价区：灰色小卡片 */
.db-personal-review {
    background: var(--color-codebg, #f5f5f5); /* 借用你原有的变量 */
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid rgba(0,0,0,0.03);
}

.db-rating-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
    font-size: 0.85rem;
    color: #888;
}

.db-stars i {
    color: #f5c518;
    font-size: 0.8rem;
}

.db-comment {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--card-text-color-main, #333);
}

/* 适配手机端 */
@media (max-width: 600px) {
    .db-official-info {
        gap: 12px;
    }
    .db-cover {
        width: 75px;
        height: 105px;
    }
    .db-title {
        font-size: 1.1rem;
    }
}
</style>