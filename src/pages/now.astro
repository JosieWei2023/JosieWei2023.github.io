---
// src/pages/now.astro
import LayoutDefault from "~/layouts/LayoutDefault.astro";
import NeoDBCard from "~/components/NeoDBCard.astro";

// 1. 获取 Token (加了 process.env 双重保险，绝对读得到)
const AUTH_TOKEN = import.meta.env.NEODB_TOKEN || process.env.NEODB_TOKEN;

if (!AUTH_TOKEN) {
  console.error("❌ 警告：未找到 NEODB_TOKEN 环境变量，请检查 GitHub Secrets！");
}

// 2. 抓取数据的通用函数
async function fetchNeoDB(category: string) {
  try {
    // 🚨 修正：把 /fetch 换成了 /complete (代表已看/已读的书架)，并加上了 page=1
    const res = await fetch(`https://neodb.social/api/me/shelf/complete?category=${category}&page=1`, {
      headers: {
        Authorization: `Bearer ${AUTH_TOKEN}`,
        Accept: 'application/json',
      },
    });
    
    if (!res.ok) {
        console.error(`NeoDB 抓取失败 (${category}): HTTP ${res.status}`);
        return [];
    }
    
    const json = await res.json();
    // 拿到数据后，只截取前 4 个展示
    return json.data ? json.data.slice(0, 4) : [];
  } catch (error) {
    console.error(`NeoDB 请求出错 (${category}):`, error);
    return [];
  }
}

// 3. 在构建时直接抓取数据
// 因为用了 api/me 接口，系统会自动识别这个 Token 属于谁，不用填用户名
const recentMovies = await fetchNeoDB('movie');
const recentBooks = await fetchNeoDB('book');

// 自动获取构建日期
const lastModified = new Date().toISOString().split('T')[0];
---

<LayoutDefault >
  <article class="heti prose mx-auto">
    <h1>Now</h1>
    <p class="text-gray-500 italic">
      最后更新于：{lastModified}
    </p>
    
    <h3>📍 当前状态</h3>
    <ul>
      <li><strong>坐标</strong> 加拿大</li>
      <li><strong>运动</strong> 从年前的腰伤中康复，目前运动主打荤素搭配：工作日健身房周末抱石和散步。</li>
      <li><strong>工作</strong>薅政府羊毛在温哥华蓝翔报名了税法课程，四月十一号开始每周六早上要去上课。三月底提出离职，五月会入职新公司继续做会计。</li>
      <li><strong>爱好</strong> 三月精神压力过大，又是沉迷网文的一个月，最近读了很多撕枕犹眠的文。</li>
      
    </ul>

    

    {/* 电影板块 */}
    {recentMovies.length > 0 && (
      <>
        <h3>🎬 最近看过</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-4">
          {recentMovies.map((record: any) => (
            <NeoDBCard record={record} />
          ))}
        </div>
      </>
    )}

    {/* 书籍板块 */}
    {recentBooks.length > 0 && (
      <>
        <h3>📚 最近读过</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-4">
          {recentBooks.map((record: any) => (
            <NeoDBCard record={record} />
          ))}
        </div>
      </>
    )}
    
    {/* 如果都没有数据，显示提示 */}
    {recentMovies.length === 0 && recentBooks.length === 0 && (
       <p class="text-gray-400 text-sm italic">暂时无法获取 NeoDB 数据，请稍后再试。</p>
    )}
    
  </article>
</LayoutDefault>